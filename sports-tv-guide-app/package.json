{
  "name": "sports-tv-guide-app",
  "version": "1.0.0",
  "description": "Mobile-first sports broadcast TV guide using Expo and React Native",
  "main": "index.tsx",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "test": "jest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@expo/metro-runtime": "~55.0.6",
    "@react-navigation/bottom-tabs": "^7.15.0",
    "@react-navigation/native": "^7.1.0",
    "@react-navigation/native-stack": "^7.14.0",
    "expo": "^55.0.5",
    "expo-local-authentication": "~55.0.8",
    "expo-secure-store": "~55.0.8",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "~4.2.2",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@testing-library/react-native": "^13.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.2.10",
    "typescript-eslint": "^8.0.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.5.0",
    "jest-expo": "~55.0.9",
    "prettier": "^3.2.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg)"
    ],
    "moduleNameMapper": {
      "^@constants/(.*)$": "<rootDir>/src/constants/$1",
      "^@types/(.*)$": "<rootDir>/src/types/$1",
      "^@services/(.*)$": "<rootDir>/src/services/$1",
      "^@store/(.*)$": "<rootDir>/src/store/$1",
      "^@components/(.*)$": "<rootDir>/src/components/$1"
    }
  }
}
